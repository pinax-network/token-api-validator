# HTTP server
PORT=3000

# ClickHouse (validation database)
CLICKHOUSE_URL=
CLICKHOUSE_USERNAME=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=validation

# Token API
# Use external URL to validate the same path as external users
TOKEN_API_BASE_URL=https://token-api.thegraph.com
# Required, get started at https://thegraph.com/docs/en/token-api/quick-start/
TOKEN_API_JWT=

# Etherscan API V2 key (optional — improves coverage on paid-only chains)
# Single key works across all chains via the unified V2 endpoint
# Both Blockscout and Etherscan are queried when available
ETHERSCAN_API_KEY=

# Pinax RPC API key (optional — authenticates RPC requests to avoid rate limits)
# Without this, RPC requests go through unauthenticated and may be throttled
PINAX_RPC_API_KEY=

# Solscan API key (optional — required for Solana reference provider)
SOLSCAN_API_KEY=

# dRPC API key (optional — enables Solana on-chain RPC reference provider)
# Auth via Drpc-Key header, endpoint: https://lb.drpc.org/ogrpc?network=solana
DRPC_API_KEY=

# CoinGecko (only used by scripts/fetch-tokens.ts, not at runtime)
COINGECKO_API_KEY=

# Scheduler
CRON_SCHEDULE=0 */6 * * *

# Provider settings
RATE_LIMIT_MS=500
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RPC_BATCH_SIZE=50

# Logging
VERBOSE=true
PRETTY_LOGGING=false
